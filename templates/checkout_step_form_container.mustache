{{!
    @template local_shopping_cart/checkout_step_form_container

    Container for a checkout step implemented as dynamic form. The
    checkout_manager JS mounts a core_form/dynamicform into it.

    Context variables required for this template:
    * formclass fully qualified dynamic_form classname
    * stepkey   short step key (cache key in the checkout manager)

    Example context (json):
    {
        "formclass": "local_shopping_cart\\local\\checkout_process\\steps\\termsandconditions_form",
        "stepkey": "termsandconditions"
    }
}}
{{#wrapperclass}}<section class="{{wrapperclass}}">{{/wrapperclass}}
{{{beforeform}}}
<div
    class="shopping-cart-checkout-step-form"
    data-shopping-cart-step-form="{{formclass}}"
    data-stepkey="{{stepkey}}"
    data-autosubmit="{{#autosubmit}}1{{/autosubmit}}"
>{{{formhtml}}}</div>
{{{afterform}}}
{{#wrapperclass}}</section>{{/wrapperclass}}
{{#js}}
    require(['local_shopping_cart/checkout_manager'], function(checkoutManager) {
    checkoutManager.initStepForms();
    });
{{/js}}
