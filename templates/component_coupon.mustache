{{!
    @template local_shopping_cart/component_coupon

    TODO describe template component_coupon

    Example context (json):
    {
    "couponenabled": false,
    "couponmessage": "Gutschein erfolgreich angewendet."
    }
}}

{{#couponenabled}}
    <div class="form-group sc_coupon">
        <label for="couponcode">
            {{#str}} coupon:entercode, local_shopping_cart {{/str}}
        </label>
        <input type="text"
            class="form-control"
            data-id="couponcode"
            name="couponcode"
            placeholder="{{#str}} coupon:entercode, local_shopping_cart {{/str}}"
            value="{{coupon}}">
    </div>
    <div class="text-right mr-3 sc_couponmessage">
        {{#couponmessage}}
            {{#couponapplied}}
                <span class="alert alert-success" role="alert">{{couponmessage}}</span>
            {{/couponapplied}}
            {{^couponapplied}}
                <span class="alert alert-danger" role="alert">{{couponmessage}}</span>
            {{/couponapplied}}
        {{/couponmessage}}
    </div>
    {{#coupondiscount}}
        <div class="text-right mr-3 sc_coupondiscount">
            <strong>{{#str}} coupondiscount, local_shopping_cart {{/str}}:</strong>
            -{{coupondiscount}} {{currency}}
        </div>
    {{/coupondiscount}}
{{/couponenabled}}