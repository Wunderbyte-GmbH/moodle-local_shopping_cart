{{#success}}
    {{> local_shopping_cart/checkout_success }}
{{/success}}
{{#failed}}
    {{> local_shopping_cart/checkout_failed }}
{{/failed}}

{{^finished}}
<div class="checkout checkoutgrid sc-checkout-modern">
{{#onlyrebooking}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
  {{#str}} rebookingalert, local_shopping_cart {{/str}}
  <button type="button" class="btn-close" data-dismiss="alert" aria-label="Close">
    <span aria-hidden="true">&times;</span>
  </button>
</div>
{{/onlyrebooking}}
    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm sc-main-card">
                <div class="card-header bg-white border-0 pb-0">
                    <ul class="nav nav-tabs sc-checkout-tabs" id="shopping-cart-main-tabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="shopping-cart-checkout-tab" data-bs-toggle="tab" data-bs-target="#shopping-cart-checkout-panel" type="button" role="tab" aria-controls="shopping-cart-checkout-panel" aria-selected="true">
                                {{#str}} checkout, local_shopping_cart {{/str}}
                            </button>
                        </li>
                        {{#has_historyitems}}
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="shopping-cart-history-tab" data-bs-toggle="tab" data-bs-target="#shopping-cart-history-panel" type="button" role="tab" aria-controls="shopping-cart-history-panel" aria-selected="false">
                                    {{#str}} previouspurchases, local_shopping_cart {{/str}}
                                </button>
                            </li>
                        {{/has_historyitems}}
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="shopping-cart-checkout-panel" role="tabpanel" aria-labelledby="shopping-cart-checkout-tab">
                            {{#checkout_manager_body}}
                                {{> local_shopping_cart/checkout_manager_form }}
                            {{/checkout_manager_body}}
                        </div>

                        {{#has_historyitems}}
                            <div class="tab-pane fade" id="shopping-cart-history-panel" role="tabpanel" aria-labelledby="shopping-cart-history-tab">
                                <div class="history">
                                    <ul class="list-group cashier-history-items">
                                        {{> local_shopping_cart/costcentercredit_item }}
                                        {{> local_shopping_cart/history_items }}
                                    </ul>
                                </div>
                            </div>
                        {{/has_historyitems}}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card border-0 shadow-sm sc-summary-card">
                <div class="card-header bg-white border-0 pb-0">
                    <h5 class="mb-1">{{#str}} yourcart, local_shopping_cart {{/str}}</h5>
                </div>
                <div class="card-body">
                    <ul class="shopping-cart-items mb-3">
                        <li class="user-card mb-2">
                            <h5 class="mb-1">{{name}}</h5>
                            <p class="mb-0 text-muted">{{mail}}</p>
                        </li>
                    </ul>

                    <div class="shopping-cart-checkout-items-container mb-3">
                        {{> local_shopping_cart/shopping_cart_items }}
                    </div>

                    <div class="sc_price_label" data-userid="{{userid}}">
                        {{> local_shopping_cart/price_label }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/finished}}

{{#js}}
    require(['local_shopping_cart/shistory'], function(fn) {
      fn.init({{cancelationfee}});
    });
{{/js}}
